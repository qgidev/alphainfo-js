{
  "name": "alphainfo",
  "version": "1.5.17",
  "description": "TypeScript/JavaScript client for the alphainfo.io Structural Intelligence API",
  "keywords": [
    "alphainfo",
    "time-series",
    "structural-analysis",
    "regime-detection",
    "anomaly-detection",
    "signal-processing"
  ],
  "homepage": "https://alphainfo.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qgidev/alphainfo-js.git"
  },
  "bugs": {
    "url": "https://github.com/qgidev/alphainfo-js/issues"
  },
  "license": "MIT",
  "author": "QGI Quantum Systems LTDA <contato@alphainfo.io> (https://qgi.com.br)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
